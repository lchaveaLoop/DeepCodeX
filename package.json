{
  "name": "fagent",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "packages/agent",
    "packages/cli"
  ],
  "scripts": {
    "dev": "npm run build -w @fagent/agent && npm run dev -w @fagent/cli",
    "build": "npm run build -w @fagent/agent && npm run build -w @fagent/cli",
    "typecheck": "npm run typecheck -w @fagent/agent && npm run build -w @fagent/agent && npm run typecheck -w @fagent/cli",
    "test": "npm run test -w @fagent/agent",
    "lint": "npm run lint -w @fagent/agent && npm run lint -w @fagent/cli",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "install-hooks": "husky install"
  },
  "lint-staged": {
    "packages/agent/src/**/*.ts": [
      "eslint --config packages/agent/eslint.config.js --fix",
      "prettier --write"
    ],
    "packages/cli/src/**/*.ts": [
      "eslint --config packages/cli/eslint.config.js --fix",
      "prettier --write"
    ],
    "*.js": [
      "prettier --write"
    ],
    "*.md": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^19.7.1",
    "@eslint/js": "^9.18.0",
    "commitlint": "^19.7.1",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.4.2",
    "typescript-eslint": "^8.21.0"
  }
}
